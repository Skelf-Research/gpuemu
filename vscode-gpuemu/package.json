{
  "name": "gpuemu",
  "displayName": "gpuemu",
  "description": "GPU-less validation for deep learning kernels",
  "version": "0.1.0",
  "publisher": "gpuemu",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Linters",
    "Other"
  ],
  "keywords": [
    "gpu",
    "validation",
    "deep learning",
    "pytorch",
    "jax",
    "tensorflow"
  ],
  "activationEvents": [
    "workspaceContains:gpuemu.toml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gpuemu.init",
        "title": "Initialize Project",
        "category": "gpuemu"
      },
      {
        "command": "gpuemu.startDaemon",
        "title": "Start Daemon",
        "category": "gpuemu"
      },
      {
        "command": "gpuemu.stopDaemon",
        "title": "Stop Daemon",
        "category": "gpuemu"
      },
      {
        "command": "gpuemu.runTests",
        "title": "Run Validation Tests",
        "category": "gpuemu"
      },
      {
        "command": "gpuemu.runQuickTests",
        "title": "Run Quick Validation",
        "category": "gpuemu"
      },
      {
        "command": "gpuemu.fuzz",
        "title": "Run Fuzz Tests",
        "category": "gpuemu"
      },
      {
        "command": "gpuemu.reproduce",
        "title": "Reproduce Failure",
        "category": "gpuemu"
      },
      {
        "command": "gpuemu.showFailures",
        "title": "Show Failures",
        "category": "gpuemu"
      }
    ],
    "configuration": {
      "title": "gpuemu",
      "properties": {
        "gpuemu.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to gpuemu binary. Leave empty for automatic detection."
        },
        "gpuemu.autoStartDaemon": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start daemon when workspace contains gpuemu.toml"
        },
        "gpuemu.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show daemon status in status bar"
        }
      }
    },
    "languages": [
      {
        "id": "gpuemu-toml",
        "aliases": ["gpuemu Config"],
        "filenames": ["gpuemu.toml"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gpuemu-toml",
        "scopeName": "source.toml.gpuemu",
        "path": "./syntaxes/gpuemu-toml.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "gpuemu-toml",
        "path": "./snippets/gpuemu.code-snippets"
      },
      {
        "language": "toml",
        "path": "./snippets/gpuemu.code-snippets"
      }
    ],
    "problemMatchers": [
      {
        "name": "gpuemu",
        "owner": "gpuemu",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^\\[FAIL\\]\\s+(\\S+)\\s+\\(seed:\\s*(\\d+)\\):\\s+(.+)$",
          "file": 1,
          "message": 3
        }
      }
    ],
    "taskDefinitions": [
      {
        "type": "gpuemu",
        "required": ["command"],
        "properties": {
          "command": {
            "type": "string",
            "description": "The gpuemu command to run"
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Additional arguments"
          }
        }
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "gpuemuFailures",
          "name": "gpuemu Failures",
          "when": "gpuemu.hasConfig"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gpuemu",
          "title": "gpuemu",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "gpuemu.runTests",
          "when": "view == gpuemuFailures",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
